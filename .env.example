# =========================================================
#             E-COM NEXT ENGINE - ROOT EXAMPLE
# =========================================================

# --- DATABASE & AUTH SECRETS (Shared) ---
MONGODB_URI=your-mongodb-connection-string
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# --- ADMIN ACCESS ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# --- GOOGLE AUTH (Shared) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- EMAIL SERVICE (Shared) ---
RESEND_API_KEY=your-resend-api-key
STORE_EMAIL_FROM_NAME=Your Store Name

# --- CLOUDINARY CONFIGURATION (Shared) ---
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- DYNAMIC STORE MAPPING (Identity & Branding) ---
NEXT_PUBLIC_STORE_KEY=your-store-key
NEXT_PUBLIC_STORE_NAME=Your Store Name
NEXT_PUBLIC_STORE_SHORT_NAME=Your Store
NEXT_PUBLIC_STORE_TAGLINE=Your store tagline
NEXT_PUBLIC_STORE_DESCRIPTION=Describe the store experience here.
NEXT_PUBLIC_STORE_CONTACT_LOCATION=Your City, Country
NEXT_PUBLIC_STORE_FOOTER_DESCRIPTION=Short footer description for the active store.

# --- LOGO & URLS ---
NEXT_PUBLIC_STORE_LOGO_TEXT_PRIMARY=Your
NEXT_PUBLIC_STORE_LOGO_TEXT_SECONDARY=Store
NEXT_PUBLIC_STORE_LOGO_URL=
NEXT_PUBLIC_STORE_LOGO_DARK_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- THEME COLORS (Extracted from globals.css for China default preset) ---
NEXT_PUBLIC_STORE_PRIMARY_COLOR=oklch(0.396 0.0722 178.59)
NEXT_PUBLIC_STORE_PRIMARY_FOREGROUND_COLOR=oklch(0.985 0.004 95)
NEXT_PUBLIC_STORE_ACCENT_COLOR=oklch(0.78 0.11 92)
NEXT_PUBLIC_STORE_ACCENT_FOREGROUND_COLOR=oklch(0.23 0.02 160)
